# ===== Report Service — пример конфигурации =====
# Скопируйте в .env и измените при необходимости

# Сетевые настройки
HOST=0.0.0.0
PORT=8080

# Ограничения
MAX_UPLOAD_SIZE_MB=100
ALLURE_TIMEOUT_SECONDS=300

# Хранилище отчётов (внутри контейнера)
REPORTS_DIR=./data/reports

# CORS — список через запятую или * для всех
CORS_ORIGINS=*

# Логирование
LOG_LEVEL=INFO
JSON_LOGS=false

# ===== Авторизация (Keycloak OIDC) =====
# Включить авторизацию
AUTH_ENABLED=false

# Keycloak
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_HOSTNAME_PORT=8081
KEYCLOAK_REALM=report-service
KEYCLOAK_CLIENT_ID=report-service
KEYCLOAK_CLIENT_SECRET=

# Публичный URL сервиса (для OAuth redirect).
# Локально:  http://localhost:8080
# На проде:  http://80.78.241.93:8080
PUBLIC_URL=http://80.78.241.93:8080

# Секрет для подписи сессионных cookie (обязательно измените в продакшене!)
SESSION_SECRET=change-me-in-production

# ===== Keycloak (docker-compose) =====
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin